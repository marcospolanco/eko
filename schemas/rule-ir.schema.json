{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eko.dev/schemas/rule-ir.schema.json",
  "title": "EKO Rule Intermediate Representation",
  "description": "A deliberately small, non-eval declarative intermediate representation for domain knowledge rules. The IR defines states, transitions, predicates, and action references without arbitrary code execution.",
  "type": "object",
  "required": ["states", "initial_state"],
  "properties": {
    "states": {
      "type": "array",
      "description": "State definitions in the rule graph.",
      "items": { "$ref": "#/$defs/state" }
    },
    "initial_state": {
      "type": "string",
      "description": "The starting state for execution (must match a state.id)."
    },
    "final_states": {
      "type": "array",
      "description": "States that represent terminal outcomes.",
      "items": { "type": "string" }
    },
    "variables": {
      "type": "array",
      "description": "Variable declarations referenced in predicates and transitions.",
      "items": { "$ref": "#/$defs/variable" }
    },
    "constants": {
      "type": "object",
      "description": "Constant values that can be referenced in predicates.",
      "additionalProperties": true
    },
    "timeout": {
      "type": "object",
      "description": "Execution timeout configuration.",
      "properties": {
        "default_seconds": {
          "type": "integer",
          "description": "Default timeout in seconds for state transitions."
        },
        "max_seconds": {
          "type": "integer",
          "description": "Maximum timeout across all execution."
        }
      }
    },
    "cycles": {
      "type": "object",
      "description": "Cycle detection and bounds.",
      "properties": {
        "max_iterations": {
          "type": "integer",
          "description": "Maximum allowed iterations before cycle error."
        },
        "detect_cycles": {
          "type": "boolean",
          "description": "Whether to enable cycle detection.",
          "default": true
        }
      }
    }
  },
  "$defs": {
    "state": {
      "type": "object",
      "description": "A state in the rule graph with transitions and optional actions.",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique state identifier."
        },
        "description": {
          "type": "string",
          "description": "Human-readable state description."
        },
        "type": {
          "type": "string",
          "enum": ["decision", "action", "approval", "terminal", "error", "escalation"],
          "description": "State type classification."
        },
        "on_entry": {
          "type": "array",
          "description": "Actions to execute when entering this state.",
          "items": { "$ref": "#/$defs/action_reference" }
        },
        "on_exit": {
          "type": "array",
          "description": "Actions to execute when exiting this state.",
          "items": { "$ref": "#/$defs/action_reference" }
        },
        "transitions": {
          "type": "array",
          "description": "Transitions from this state to other states.",
          "items": { "$ref": "#/$defs/transition" }
        },
        "approval": {
          "$ref": "#/$defs/approval_gate",
          "description": "Approval gate configuration (required for type=approval)."
        },
        "error_handling": {
          "type": "object",
          "description": "Error behavior for this state.",
          "properties": {
            "on_error": {
              "type": "string",
              "enum": ["retry", "escalate", "terminate", "transition_to"],
              "description": "Behavior when an error occurs in this state."
            },
            "retry_policy": {
              "type": "object",
              "description": "Retry configuration.",
              "properties": {
                "max_retries": { "type": "integer" },
                "backoff": {
                  "type": "string",
                  "enum": ["fixed", "exponential", "linear"]
                },
                "base_delay_ms": { "type": "integer" }
              }
            },
            "error_target": {
              "type": "string",
              "description": "Target state for transition_to or escalate."
            }
          }
        }
      }
    },
    "transition": {
      "type": "object",
      "description": "A transition from one state to another, conditional on predicates.",
      "required": ["to"],
      "properties": {
        "condition": {
          "type": "string",
          "description": "Predicate expression that must evaluate to true for this transition."
        },
        "to": {
          "type": "string",
          "description": "Target state ID."
        },
        "priority": {
          "type": "integer",
          "description": "Transition priority (higher evaluated first)."
        },
        "action": {
          "$ref": "#/$defs/action_reference",
          "description": "Action to execute during this transition."
        },
        "label": {
          "type": "string",
          "description": "Human-readable label for this transition."
        }
      }
    },
    "predicate": {
      "type": "object",
      "description": "A predicate expression that evaluates to true, false, or unknown.",
      "required": ["expression"],
      "properties": {
        "expression": {
          "type": "string",
          "description": "Predicate expression using variables, constants, and operators."
        },
        "on_unknown": {
          "type": "string",
          "enum": ["eval_false", "eval_true", "eval_unknown", "error"],
          "description": "How to handle unknown values in evaluation."
        }
      }
    },
    "action_reference": {
      "type": "object",
      "description": "A reference to an action capability (not the implementation).",
      "required": ["type", "target"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["capability", "procedure", "notification", "state_change", "compensation"],
          "description": "Action type."
        },
        "target": {
          "type": "string",
          "description": "Capability or procedure identifier."
        },
        "parameters": {
          "type": "object",
          "description": "Parameter bindings for this action invocation.",
          "additionalProperties": true
        },
        "idempotency_key": {
          "type": "string",
          "description": "Optional idempotency key for this invocation."
        }
      }
    },
    "variable": {
      "type": "object",
      "description": "Variable declaration for use in predicates.",
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Variable name."
        },
        "type": {
          "type": "string",
          "enum": ["string", "number", "integer", "boolean", "datetime", "decimal", "enum", "unknown"],
          "description": "Variable data type."
        },
        "source": {
          "type": "string",
          "description": "Source for this variable (fact binding, computed, etc.)."
        },
        "default": {
          "description": "Default value if not provided."
        },
        "allowed_values": {
          "type": "array",
          "description": "Allowed values for enum types.",
          "items": { "type": "string" }
        }
      }
    },
    "approval_gate": {
      "type": "object",
      "description": "Approval gate configuration for states requiring human or automated approval.",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["human", "automated", "hybrid"],
          "description": "Approval type."
        },
        "approvers": {
          "type": "array",
          "description": "Required approvers (for human or hybrid).",
          "items": { "type": "string" }
        },
        "approval_criteria": {
          "type": "string",
          "description": "Predicate that must be satisfied for approval."
        },
        "timeout": {
          "type": "integer",
          "description": "Approval timeout in seconds."
        },
        "on_timeout": {
          "type": "string",
          "enum": ["escalate", "deny", "auto_approve"],
          "description": "Behavior when approval times out."
        },
        "escalation_target": {
          "type": "string",
          "description": "Escalation target on timeout."
        },
        "min_required": {
          "type": "integer",
          "description": "Minimum number of approvals required."
        },
        "auto_approve_if": {
          "type": "string",
          "description": "Predicate for automatic approval (hybrid type)."
        }
      }
    },
    "operator": {
      "type": "string",
      "enum": ["==", "!=", "<", ">", "<=", ">=", "and", "or", "not", "in", "not_in", "is_unknown", "is_known"],
      "description": "Supported operators in predicate expressions."
    }
  }
}
